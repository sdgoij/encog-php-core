{
  "name": "sdgoij/encog",
  "description": "Encog Machine Learning Framework",
  "license": "Apache-2",
  "keywords": [
    "machine learning",
    "stuff"
  ],
  "homepage": "http://github.com/sdgoij/encog-php-core",
  "authors": [
    {
      "name": "Tim Jurcka",
      "email": "sdgoij@gmail.com",
      "homepage": "http://github.com/sdgoij/"
    }
  ],
  "scripts": {
    "phpstan": "phpstan analyse",
    "cs-fixer": "php-cs-fixer fix --dry-run --diff",
    "test": "phpunit",
    "static-analysis": [
      "@phpstan",
      "@cs-fixer"
    ]
  },
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^9",
    "friendsofphp/php-cs-fixer": "^3.73",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "encog\\": "src/",
      "encog\\test\\": "tests/"
    }
  }
}
